rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn(){ return request.auth != null; }
    function isAdmin(){ return signedIn() && exists(/databases/$(database)/documents/roles/$(request.auth.uid)) && get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role == 'admin'; }
    function isEditor(){ return signedIn() && exists(/databases/$(database)/documents/roles/$(request.auth.uid)) && (get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role in ['admin','editor']); }
    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create, update: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow delete: if isAdmin();
    }
    match /roles/{uid} { allow read: if signedIn(); allow write: if isAdmin(); }
    match /families/{familyId}/{document=**} {
      allow read: if signedIn();
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }
    match /securityLogs/{logId} { allow create: if signedIn(); allow read, update, delete: if isAdmin(); }
    match /{document=**} { allow read, write: if false; }
  }
}
