rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdminEmail() { return signedIn() && request.auth.token.email == "alibahripor33@gmail.com"; }
    function role() {
      return isAdminEmail() ? "admin" :
        (signedIn() && exists(/databases/$(database)/documents/roles/$(request.auth.uid))
          ? get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role
          : "viewer");
    }
    function canRead() { return signedIn(); }
    function canWrite() { return role() in ["admin", "editor"]; }
    function canAdmin() { return role() == "admin"; }

    match /families/{familyId} {
      allow read: if canRead();
      allow create, update: if canWrite();
      allow delete: if canAdmin();
    }
    match /roles/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || canAdmin());
      allow create, update, delete: if canAdmin();
    }
    match /securityLogs/{logId} {
      allow create: if signedIn();
      allow read: if canAdmin();
      allow update, delete: if false;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
