rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.email == 'alibahripor33@gmail.com'
      );
    }

    function isEditor() {
      return isSignedIn() && (
        request.auth.token.editor == true ||
        request.auth.token.admin == true ||
        request.auth.token.email == 'alibahripor33@gmail.com'
      );
    }

    match /{document=**} {
      allow read: if isSignedIn();
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }
  }
}
